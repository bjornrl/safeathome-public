NEXT_PUBLIC_SUPABASE_URL=https://ditsssyrzjqdnhqxnffx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Dev-mode public lock. When set to "1", only `/`, `/auth*`, and (for
# signed-in users) `/admin*` are reachable; every other route redirects
# to `/`. Leave unset (or set to "0") to disable.
NEXT_PUBLIC_DEV_LOCK=1

# Server-only. Powers the "✦ Suggest" button on Quick Notes (Claude Haiku).
# Must also be set in Netlify env for production. When unset, the button
# is hidden entirely (no client-visible failure).
ANTHROPIC_API_KEY=sk-ant-...

# Server-only. Powers semantic search & embeddings (ADR 0001).
# Must also be set in Netlify env for production. When unset, embedding is
# skipped and /internal/search degrades to keyword-only — no client failure.
OPENAI_API_KEY=sk-...

# Server-only, OPS ONLY (never shipped to the client / Netlify functions).
# Used by scripts/backfill-embeddings.mjs to bypass RLS and re-embed all rows.
# Find it in Supabase → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=ey...
